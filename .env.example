# URL canonique (sans slash final) — SEO : canonical, Open Graph, JSON-LD
VITE_SITE_URL=https://www.dys-ponible.fr

# ── Vercel (production) ─────────────────────────────────────────────
# 1. Project → Settings → Domains → ajouter :
#      • dys-ponible.fr
#      • www.dys-ponible.fr
# 2. Project → Settings → Environment Variables → ajouter :
#      VITE_SITE_URL = https://www.dys-ponible.fr  (Production)
#      VITE_WEB3FORMS_ACCESS_KEY = votre_clé  (Production)
# 3. Redéployer après avoir ajouté les variables.
#
# Le .env local sert uniquement au dev (npm run dev). Il n'est pas poussé sur Git.

# ── Formulaire de contact (Web3Forms — gratuit) ─────────────────────
# 1. Aller sur https://web3forms.com
# 2. Entrer l’email de réception : ayouazsouhad@gmail.com
# 3. Copier la clé d’accès reçue par email
# 4. Coller ci-dessous (local) et dans Vercel → Environment Variables
VITE_WEB3FORMS_ACCESS_KEY=
